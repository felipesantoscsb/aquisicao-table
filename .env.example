# ID do Pixel da Meta (encontrado no Gerenciador de Eventos)
META_PIXEL_ID=SEU_PIXEL_ID_AQUI

# Token de acesso da Conversions API (gerado no Gerenciador de Eventos > Configurações)
META_CAPI_TOKEN=SEU_TOKEN_CAPI_AQUI

# Código de teste da CAPI (gerado em Gerenciador de Eventos > Testar Eventos).
# Preencha durante testes e deixe VAZIO ou REMOVA em produção.
META_TEST_EVENT_CODE=

# Segredo compartilhado com o sdr-table para autenticar o forward de leads do quiz e da captação
SDR_WEBHOOK_SECRET=

# Opcional: sobrescreve o endpoint do sdr-table usado pelo formulário /conversa
SDR_LEAD_WEBHOOK_URL=https://table-production-07c5.up.railway.app/webhook/lead

# Segredo compartilhado com o hub-tableclinic para webhooks internos
HUB_WEBHOOK_SECRET=

# Opcional: sobrescreve o endpoint do Hub usado pelo formulário /forms
HUB_PRE_SESSAO_WEBHOOK_URL=https://crm.tableclinic.com.br/webhook/pre-sessao
